# ClauseAI Backend - Environment Configuration
# Copy to .env and fill in values

# Server
NODE_ENV=development
PORT=3000

# Supabase (Auth + Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Encryption (32-byte hex for AES-256; generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-key

# AWS (optional - for secrets storage; used if ENCRYPTION_KEY not set or for backup)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SECRETS_PREFIX=clauseai/

# Logging
LOG_LEVEL=info
